{
  "name": "hinata-bot",
  "version": "1.1.0",
  "description": "Bot de WhatsApp HINATA - Bot multifuncional con comandos de anime, juegos, economía y más",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "node --test **/*.test.js",
    "build": "node build.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preinstall": "echo Installing dependencies...",
    "postinstall": "echo Bot ready!",
    "clean": "rm -rf node_modules/.cache"
  },
  "engines": {
    "node": ">=20.0.0 <22.0.0",
    "npm": ">=10.0.0"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "hinata",
    "anime",
    "multimedia",
    "whatsapp-bot",
    "baileys"
  ],
  "author": "Nicolas Sanilo",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicolassanilo/HINATA---BOT-.git"
  },
  "bugs": {
    "url": "https://github.com/nicolassanilo/HINATA---BOT-/issues"
  },
  "homepage": "https://github.com/nicolassanilo/HINATA---BOT-#readme",
  "funding": {
    "type": "git",
    "url": "https://github.com/nicolassanilo/HINATA---BOT-"
  },
  "license": "MIT",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^6.7.2",
    "axios": "^1.6.8",
    "express": "^4.18.0",
    "fluent-ffmpeg": "^2.1.2",
    "pino": "^8.17.2",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "yt-search": "^2.10.4",
    "ytdl-core": "^4.11.5"
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  },
  "overrides": {
    "sqlite3": {
      "bindings": "1.5.0"
    }
  },
  "volta": {
    "node": "20.11.0",
    "npm": "10.2.4"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100
  },
  "eslintConfig": {
    "env": {
      "es2022": true,
      "node": true
    },
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    }
  }
}
