# Configuración de HINATA-BOT v3.0
# Copia este archivo a .env y ajusta los valores

# ================================
# CONFIGURACIÓN PRINCIPAL DEL BOT
# ================================
BOT_OWNER_NUMBER=549XXXXXXXXXX@c.us
BOT_PREFIX=.
SESSION_NAME=HINATA-BOT
NODE_ENV=production
TZ=America/Argentina/Buenos_Aires

# ================================
# API KEYS (Opcional pero recomendado)
# ================================
# Para Pinterest (búsqueda de imágenes)
PEXELS_API_KEY=tu_api_key_de_pexels_aqui

# Para IA Gemini
GEMINI_API_KEY=tu_gemini_api_key_aqui

# Para IA OpenAI/DALL-E
OPENAI_API_KEY=tu_openai_api_key_aqui

# Para otras APIs
UNSPLASH_API_KEY=tu_api_key_de_unsplash_aqui

# ================================
# CONFIGURACIÓN DE BASE DE DATOS
# ================================
# Si usas MongoDB (opcional)
DB_HOST=mongodb
DB_PORT=27017
DB_NAME=hinata_bot
DB_USER=admin
DB_PASS=password123

# Si usas SQLite (por defecto)
SQLITE_PATH=./data/hinata_bot.db

# ================================
# CONFIGURACIÓN DE SERVIDOR WEB
# ================================
WEB_PORT=3000
WEB_HOST=0.0.0.0
WEB_ENABLED=false

# ================================
# CONFIGURACIÓN DE RENDIMIENTO
# ================================
MAX_MEMORY=2048
WORKERS=1
DEBUG=false
LOG_LEVEL=info

# ================================
# CONFIGURACIÓN DE WHATSAPP
# ================================
# Número del bot (formato internacional)
BOT_NUMBER=549XXXXXXXXXX@c.us

# Configuración de sesión
SESSION_TIMEOUT=86400
AUTO_RECONNECT=true
QR_TIMEOUT=60

# ================================
# CONFIGURACIÓN DE SEGURIDAD
# ================================
# Token secreto para webhooks (si aplica)
WEBHOOK_SECRET=tu_secreto_webhook_aqui

# Lista blanca de números (separados por comas)
WHITELIST_NUMBERS=

# Lista negra de números (separados por comas)
BLACKLIST_NUMBERS=

# ================================
# CONFIGURACIÓN DE SISTEMA WAIFU
# ================================
# Configuración del sistema de niveles
WAIFU_MAX_LEVEL=100
WAIFU_BASE_EXP=100
WAIFU_EXP_MULTIPLIER=1.5

# Configuración de combate
BATTLE_COOLDOWN=3600000
INTERACTION_COOLDOWN=1800000

# ================================
# CONFIGURACIÓN DE ECONOMÍA
# ================================
# Moneda del bot
CURRENCY_NAME=HinataCoins
CURRENCY_SYMBOL=💰

# Saldo inicial
STARTING_BALANCE=1000
MAX_BALANCE=10000000

# Configuración de trabajo
WORK_COOLDOWN=300000
WORK_MIN_REWARD=50
WORK_MAX_REWARD=500

# Configuración de robos
ROB_COOLDOWN=7200000
ROB_SUCCESS_RATE=0.3
ROB_MIN_AMOUNT=100
ROB_MAX_AMOUNT=1000

# ================================
# CONFIGURACIÓN DE MULTIMEDIA
# ================================
# Descarga de música
MUSIC_QUALITY=high
MAX_MUSIC_SIZE=50000000

# Descarga de videos
MAX_VIDEO_SIZE=50000000
VIDEO_FORMAT=mp4

# Configuración de stickers
STICKER_QUALITY=high
STICKER_PACK_NAME=HINATA-BOT

# ================================
# CONFIGURACIÓN DE LOGS
# ================================
LOG_FILE=./logs/bot.log
LOG_MAX_SIZE=10MB
LOG_MAX_FILES=5
LOG_TO_CONSOLE=true

# ================================
# CONFIGURACIÓN AVANZADA
# ================================
# Configuración de caché
CACHE_TTL=300000
CACHE_MAX_SIZE=1000

# Configuración de rate limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# Configuración de proxy (si aplica)
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=

# ================================
# VARIABLES DE ENTORNO DE DESARROLLO
# ================================
# No usar en producción
DEV_MODE=false
TEST_MODE=false
MOCK_APIS=false
